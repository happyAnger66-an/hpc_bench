{
  "name": "rmsnorm_h4096",
  "op_type": "rmsnorm",
  "description": "Root Mean Square Layer Normalization",
  "axes": {
    "batch_size": {
      "type": "var",
      "description": "Batch size"
    },
    "hidden_size": {
      "type": "const",
      "value": 4096,
      "description": "Hidden dimension"
    }
  },
  "inputs": {
    "input": {
      "shape": ["batch_size", "hidden_size"],
      "dtype": "bfloat16",
      "description": "Input tensor"
    },
    "weight": {
      "shape": ["hidden_size"],
      "dtype": "bfloat16",
      "description": "Weight parameter"
    },
    "eps": {
      "shape": null,
      "dtype": "float32",
      "description": "Epsilon for numerical stability"
    }
  },
  "outputs": {
    "output": {
      "shape": ["batch_size", "hidden_size"],
      "dtype": "bfloat16",
      "description": "Normalized output"
    }
  },
  "reference": "import torch\n\ndef run(input, weight, eps):\n    variance = input.to(torch.float32).pow(2).mean(-1, keepdim=True)\n    rstd = torch.rsqrt(variance + eps)\n    hidden_states = input * rstd\n    return (hidden_states * weight).to(input.dtype)"
}
