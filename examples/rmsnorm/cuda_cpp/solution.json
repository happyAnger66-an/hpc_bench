{
  "name": "rmsnorm_cuda_v1",
  "definition": "rmsnorm_h4096",
  "author": "hpc_bench",
  "description": "CUDA C++ implementation of RMSNorm with bfloat16 vectorization",
  "spec": {
    "languages": ["cuda_cpp"],
    "target_hardware": ["LOCAL", "B200"],
    "entry_point": "kernel.cu::run",
    "destination_passing_style": true,
    "binding": "torch",
    "dependencies": ["torch"],
    "compile_options": {
      "cuda_cflags": ["-O3", "--use_fast_math", "-std=c++17"],
      "ld_flags": ["-lcuda"]
    }
  },
  "sources": [
    {
      "path": "kernel.cu"
    }
  ]
}
